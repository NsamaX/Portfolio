# EmailJS — contact form (https://dashboard.emailjs.com)
# Create a service + template, then set the target inbox to vijuksama@gmail.com
# in the EmailJS template ("To Email" field). The template should read these
# variables from the form: {{from_name}}, {{reply_to}}, {{message}}.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Public site URL used for SEO metadata / sitemap (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
